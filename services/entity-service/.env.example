SERVER_PORT=8081

# ── Neon PostgreSQL — entity_db (ep-red-mud-aneu35a9, region: c-6 us-east-1) ──
# BUG FIX: was incorrectly pointing to ep-summer-field (identity-service endpoint)
DB_URL=jdbc:postgresql://ep-red-mud-aneu35a9-pooler.c-6.us-east-1.aws.neon.tech/entity_db?sslmode=require&channelBinding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_neon_password

# ── Inter-service (use Docker hostnames in compose, localhost for local dev) ──
IDENTITY_BASE_URL=http://localhost:8080
IDENTITY_USER_EXISTS_PATH=/api/v1/internal/users/{userId}/exists

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ENTITY_TOPIC_CREATED=fastlink.entity.created.v1
ENTITY_TOPIC_UPDATED=fastlink.entity.updated.v1
ENTITY_TOPIC_DELETED=fastlink.entity.deleted.v1
ENTITY_TOPIC_MEMBER_ASSIGNED=fastlink.entity.member.assigned.v1
