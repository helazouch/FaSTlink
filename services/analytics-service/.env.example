SERVER_PORT=8088

# ── Neon PostgreSQL — analytics_db (ep-misty-credit-andnetfk, region: c-6 us-east-1) ──
# BUG FIX: was pointing to localhost:5432 (local DB)
DB_URL=jdbc:postgresql://ep-misty-credit-andnetfk-pooler.c-6.us-east-1.aws.neon.tech/analytics_db?sslmode=require&channelBinding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_neon_password

# ── JWT (shared secret — same value in all services) ──
JWT_SECRET_BASE64=replace_with_base64_secret
JWT_ISSUER=fast-link-identity

# ── Inter-service (use Docker hostnames in compose, localhost for local dev) ──
ENTITY_BASE_URL=http://localhost:8081
ENTITY_PERMISSION_CHECK_PATH=/api/v1/internal/entities/{entiteId}/permissions/check
NOTIFICATION_BASE_URL=http://localhost:8087

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=analytics-service
PUBLICATION_TOPIC_CREATED=fastlink.publication.created.v1
EVENT_TOPIC_CREATED=fastlink.event.created.v1
REQUEST_TOPIC_SUBMITTED=fastlink.request.submitted.v1
REQUEST_TOPIC_APPROVED=fastlink.request.approved.v1
REQUEST_TOPIC_REJECTED=fastlink.request.rejected.v1
ENTITY_TOPIC_MEMBER_ASSIGNED=fastlink.entity.member.assigned.v1
