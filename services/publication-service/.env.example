SERVER_PORT=8082

# ── Neon PostgreSQL — publication_db (ep-blue-cell-amxmsbaz, region: c-5 us-east-1) ──
DB_URL=jdbc:postgresql://ep-blue-cell-amxmsbaz-pooler.c-5.us-east-1.aws.neon.tech/publication_db?sslmode=require&channelBinding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_neon_password

# ── JWT (shared secret — same value in all services) ──
JWT_SECRET_BASE64=replace_with_base64_secret
JWT_ISSUER=fast-link-identity

# ── Inter-service (use Docker hostnames in compose, localhost for local dev) ──
ENTITY_BASE_URL=http://localhost:8081
ENTITY_PERMISSION_CHECK_PATH=/api/v1/internal/entities/{entiteId}/permissions/check
NOTIFICATION_BASE_URL=http://localhost:8087

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PUBLICATION_TOPIC_CREATED=fastlink.publication.created.v1
