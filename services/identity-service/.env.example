SERVER_PORT=8080

# ── Neon PostgreSQL — identity_db (ep-summer-field-amn2wvfd, region: c-5 us-east-1) ──
DB_URL=jdbc:postgresql://ep-summer-field-amn2wvfd-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channelBinding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_neon_password

# ── JWT (shared secret — same value in all services) ──
JWT_SECRET_BASE64=replace_with_base64_secret
JWT_ISSUER=fast-link-identity
JWT_EXPIRATION_MS=3600000

# ── Flyway ──
SPRING_FLYWAY_IGNORE_MIGRATION_PATTERNS=*:missing

# ── Inter-service (use Docker hostnames in compose, localhost for local dev) ──
ENTITY_SERVICE_BASE_URL=http://localhost:8081

# ── Admin bootstrap ──
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_FULL_NAME=Platform Admin
ADMIN_BOOTSTRAP_EMAIL=admin@fastlink.dev
ADMIN_BOOTSTRAP_PASSWORD=Admin123!
