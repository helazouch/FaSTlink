SERVER_PORT=8087

# ── Neon PostgreSQL — notification_db (ep-morning-water-amndb0ln, region: c-5 us-east-1) ──
# BUG FIX: was pointing to localhost:5432 (local DB)
DB_URL=jdbc:postgresql://ep-morning-water-amndb0ln-pooler.c-5.us-east-1.aws.neon.tech/notification_db?sslmode=require&channelBinding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_neon_password

# ── Kafka ──
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=notification-service
EVENT_TOPIC_CREATED=fastlink.event.created.v1
REQUEST_TOPIC_SUBMITTED=fastlink.request.submitted.v1
REQUEST_TOPIC_APPROVED=fastlink.request.approved.v1
REQUEST_TOPIC_REJECTED=fastlink.request.rejected.v1

# ── WebSocket ──
WEBSOCKET_ALLOWED_ORIGINS=*
