# ────────────────────────────────────────────────────────────
# API Gateway (proxied by Vite devserver → http://localhost:8086)
# ────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ────────────────────────────────────────────────────────────
# WebSocket – community chat (community-service:8084 via gateway)
# ────────────────────────────────────────────────────────────
VITE_WS_COMMUNITY_URL=/ws-community
VITE_CHAT_TOPIC_PREFIX=/topic/communities
VITE_CHAT_DESTINATION=/app/communities/{communityId}/send

# ────────────────────────────────────────────────────────────
# WebSocket – notifications (notification-service:8087 via gateway)
# ────────────────────────────────────────────────────────────
VITE_WS_NOTIFICATION_URL=/ws-notifications
VITE_NOTIFICATION_TOPIC_PREFIX=/topic/users

# ────────────────────────────────────────────────────────────
# Feature flags
# ────────────────────────────────────────────────────────────
VITE_ENABLE_WEBSOCKET=true

# ────────────────────────────────────────────────────────────
# Feed – number of posts per page
# ────────────────────────────────────────────────────────────
VITE_FEED_PAGE_SIZE=10

# ────────────────────────────────────────────────────────────
# Default entity (organisation) used for analytics dashboard.
# Set this to a real entity ID present in Neon entity_db.
# ────────────────────────────────────────────────────────────
VITE_DEFAULT_ENTITY_ID=1

# ────────────────────────────────────────────────────────────
# Default community used as fallback for the general chat room.
# Set this to a real community ID present in Neon community_db.
# ────────────────────────────────────────────────────────────
VITE_DEFAULT_COMMUNITY_ID=1
