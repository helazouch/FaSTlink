# ────────────────────────────────────────────────────────────
# API Gateway
# In development, Vite proxies /api → http://localhost:8086
# In production, point to the deployed API Gateway URL
# ────────────────────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ────────────────────────────────────────────────────────────
# WebSocket – community chat (community-service via API Gateway)
# ────────────────────────────────────────────────────────────
VITE_WS_COMMUNITY_URL=/ws-community
VITE_CHAT_TOPIC_PREFIX=/topic/communities
VITE_CHAT_DESTINATION=/app/communities/{communityId}/send

# ────────────────────────────────────────────────────────────
# WebSocket – real-time notifications (notification-service via API Gateway)
# ────────────────────────────────────────────────────────────
VITE_WS_NOTIFICATION_URL=/ws-notifications
VITE_NOTIFICATION_TOPIC_PREFIX=/topic/users

# ────────────────────────────────────────────────────────────
# Feature flags
# ────────────────────────────────────────────────────────────
VITE_ENABLE_WEBSOCKET=true

# ────────────────────────────────────────────────────────────
# Feed
# ────────────────────────────────────────────────────────────
VITE_FEED_PAGE_SIZE=10

# ────────────────────────────────────────────────────────────
# Analytics dashboard: set to a real entity ID in Neon entity_db
# ────────────────────────────────────────────────────────────
VITE_DEFAULT_ENTITY_ID=1

# ────────────────────────────────────────────────────────────
# General chat room fallback: set to a real community ID in Neon community_db
# ────────────────────────────────────────────────────────────
VITE_DEFAULT_COMMUNITY_ID=1
